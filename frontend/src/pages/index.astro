---
import LandingLayout from "../layouts/LandingLayout.astro";
import SpaceBackground from "../components/SpaceBackground.astro";
import { agents } from "../components/agentIcons.ts";

// Single static marketing landing. Reversed-pyramid "viral dev tool" shape:
//   pager + wordmark  ->  one very catchy hero line  ->  one explanatory sentence
//   ->  copy-paste setup  ->  it comes alive (real agent-request cards)
//   ->  the flow  ->  why we built this  ->  demoted crypto/trust  ->  footer.
// Black + green palette over an animated starfield/aurora (SpaceBackground). No
// React island: nothing here is interactive beyond plain links + one tiny copy
// script, so it ships as pure HTML/CSS (the PWA lives at /app). All custom CSS
// lives in the scoped <style> below (NEVER inline style= attributes, which the
// strict CSP in astro.config.mjs experimental.csp: style-src 'self' + per-build
// hashes, no 'unsafe-inline' would block at runtime). Astro bundles scoped styles
// into a linked/inlined stylesheet, covered by style-src.

const REPO_URL = "https://github.com/askahuman/askahuman";
const NPM_URL = "https://www.npmjs.com/package/@askahuman/mcp";
const APP_URL = "/app";
const PAGER = "/icons/pager.svg";

const META_TITLE = "ask-a-human: a private pager for agent loops";
const META_DESCRIPTION =
  "Your agents run full-auto. When one needs a human, it pings your phone and waits. End-to-end encrypted between your agent and your phone. No account, no key.";

const mcpSnippet = `{
  "mcpServers": {
    "ask-a-human": {
      "command": "npx",
      "args": ["-y", "@askahuman/mcp", "serve"]
    }
  }
}`;

const trustChips = [
  "End-to-end encrypted",
  "No accounts",
  "No database",
  "No tracking",
  "Open-source",
];

// The flow: agent hits a wall, sealed wormhole, phone buzz, you tap, rolls on.
const flowSteps = [
  "Agent hits a wall it shouldn't pass alone",
  "Sealed in a wormhole",
  "Buzzes your phone",
  "You tap: approve, decline, or reply",
  "Agent unblocks and rolls on",
];

// The example cards mirror the real flow: pair once, then the three request
// types (yes/no, multiple choice, free-form reply). Card 1 (pairing) uses our
// pager mark; the others use the agent's real brand icon (from agentIcons).
const iconByName: Record<string, string> = Object.fromEntries(
  agents.map((a) => [a.name, a.svg]),
);

interface Card {
  kind: "pair" | "yesno" | "choice" | "text";
  agent: string;
  sub: string;
  body: string;
  icon?: string;
  code?: string;
  actions?: string[];
  placeholder?: string;
}

const cards: Card[] = [
  {
    kind: "pair",
    agent: "New agent",
    sub: "wants to pair",
    body: "Open ask-a-human.ai/app on your phone and type the 8-character code it printed to connect.",
    code: "ABCD-2345",
  },
  {
    kind: "yesno",
    agent: "Claude Code",
    icon: iconByName["Claude Code"],
    sub: "stuck on a risky deploy",
    body: "All tests pass, but this release also runs a migration that drops `orders.coupon_code` on prod. Ship it?",
    actions: ["Approve", "Decline"],
  },
  {
    kind: "choice",
    agent: "Codex",
    icon: iconByName["Codex"],
    sub: "blocked, needs your call",
    body: "`main` has been red for 20 min and 3 deploys are stuck behind it. How do I unblock it?",
    actions: ["Revert it", "Hotfix forward", "Hold, I'll look"],
  },
  {
    kind: "text",
    agent: "Cursor",
    icon: iconByName["Cursor"],
    sub: "needs your words",
    body: "A customer is escalating in the support thread and demanding a refund I'm not allowed to approve. How should I reply?",
    placeholder: "Type your reply…",
  },
];

// Tone of an action pill: the explicit yes/no answers are colored (approve ->
// green, decline -> red); every other label (the open-ended choices) stays
// neutral grey so no single option is implied to be "the safe one".
const actionTone = (label: string): "approve" | "decline" | "neutral" => {
  const l = label.toLowerCase();
  if (l.startsWith("approve")) return "approve";
  if (l.startsWith("decline")) return "decline";
  return "neutral";
};

// The "Works with your agents" list (name + brand icon + highlight) lives in
// ../components/agentIcons.ts (imported above) so the long SVG paths stay out of
// this file.

const whyParagraphs = [
  "We run a lot of agents. Like a hundred of them, in loops, full-auto, full permissions, mostly while we're asleep or away from the keyboard. That's the whole point: they're not supposed to need us. Until, every so often, one of them does.",
  "And when an agent on full-auto hits the one step it shouldn't take alone, it has no way to reach us. It can't pause a hundred loops and wait by the door. So the choices were both bad: babysit every step and kill the automation, or let it rip and hope nothing touches prod while we sleep. We wanted a third option. Let them all run wide open, and give the rare one that's stuck a way to tap us on the shoulder.",
  "So we built a pager. Copy-paste one MCP server into your agent, pin this site to your iPhone home screen, and that's it. Nothing to install, no account, no API key. When any of your agents needs a yes or no, a choice, or a quick reply, it pings your phone and waits. A hundred agents, one place, one buzz at a time.",
  "And it's private by design. The messages travel through a magic wormhole, end-to-end encrypted, so the relay in the middle is blind. We don't track anything, there's no database, and we pay for the hosting ourselves, all of it. No data to sell, no funnel, no catch. We built it because we needed it, and our only goal is for it to spread.",
];

const features = [
  {
    title: "Content-blind relay",
    body: "The server only ever sees base64(nonce‖ciphertext) and which room talks to which. It's a dumb pipe: never the data, never a decision.",
  },
  {
    title: "SPAKE2 pairing",
    body: "A short pairing code becomes a strong shared key via a Magic-Wormhole-style SPAKE2 handshake. No relay-in-the-middle can read or forge it.",
  },
  {
    title: "End-to-end encrypted",
    body: "Your agent and your phone hold the keys. Approvals are sealed on one side and opened on the other. Nowhere in between.",
  },
  {
    title: "No DB, open-source",
    body: "RAM-only, no accounts, no database. Restart means re-pair. Self-host the relay and web with a flag, or read every line on GitHub.",
  },
];
---

<LandingLayout title={META_TITLE} description={META_DESCRIPTION}>
  <!-- Animated space-green background: fixed behind everything, never interactive. -->
  <SpaceBackground />

  <main class="relative z-10">
    <!-- ───────────────────────── Hero (reversed pyramid) ───────────────────────── -->
    <section class="mx-auto max-w-4xl px-6 pt-20 pb-16 text-center sm:pt-28 sm:pb-20">
      <img src={PAGER} alt="" width="128" height="128" class="hero-pager mx-auto" />

      <div class="wordmark rise rise-1 mt-5 font-mono text-lg font-semibold tracking-tight sm:text-xl">
        ask-a-human
      </div>

      <h1
        class="rise rise-2 mx-auto mt-5 max-w-3xl text-balance font-sans text-[2.6rem] font-semibold leading-[1.05] tracking-tight text-text sm:text-6xl"
      >
        A <span class="hero-accent">private pager</span> for your agent loops.
      </h1>

      <p class="rise rise-3 mx-auto mt-6 max-w-2xl text-pretty text-base text-muted sm:text-lg">
        Run your agents full-auto in loops. When one actually needs a human, it
        pings your phone and waits.
      </p>

      <div class="rise rise-4 mt-8 flex flex-wrap items-center justify-center gap-x-2.5 gap-y-2 text-xs text-muted">
        {
          trustChips.map((chip, i) => (
            <Fragment>
              {i > 0 && <span class="text-faint" aria-hidden="true">·</span>}
              <span class="inline-flex items-center gap-1.5">
                <span class="size-1.5 rounded-full bg-approve/80"></span>
                {chip}
              </span>
            </Fragment>
          ))
        }
      </div>

      <div class="rise rise-5 mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={REPO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-border bg-surface/50 px-6 py-3.5 font-sans text-sm font-semibold text-text backdrop-blur transition hover:bg-surface sm:w-auto"
        >
          <svg viewBox="0 0 16 16" aria-hidden="true" class="size-4 fill-current">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
          </svg>
          GitHub
        </a>
        <a
          href={APP_URL}
          class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-approve px-6 py-3.5 font-sans text-sm font-semibold text-page shadow-lg shadow-approve/25 transition hover:brightness-110 sm:w-auto"
        >
          <span aria-hidden="true">📱</span>
          Open the app
        </a>
        <a
          href="#setup"
          data-copy-config
          aria-live="polite"
          class="group inline-flex w-full items-center justify-center gap-2 rounded-xl border border-border bg-surface/50 px-6 py-3.5 font-sans text-sm font-semibold text-text backdrop-blur transition hover:bg-surface sm:w-auto"
        >
          <span aria-hidden="true">📋</span>
          <span data-copy-label>Copy the config</span>
        </a>
      </div>
    </section>

    <!-- ───────────────────────── Setup (how to set it up) ───────────────────────── -->
    <section id="setup" class="mx-auto max-w-3xl scroll-mt-8 px-6 pb-20">
      <div class="text-center">
        <h2 class="font-sans text-2xl font-semibold tracking-tight text-text sm:text-3xl">
          Paste this. That's the whole setup.
        </h2>
        <p class="mx-auto mt-3 max-w-2xl text-pretty text-muted">
          No account, no API key, nothing to install or build. Drop this into your
          <code class="rounded bg-surface px-1.5 py-0.5 text-sm text-text">mcp.json</code>
          and your phone is now a tool your agent can call.
        </p>
      </div>

      <div class="mt-8 overflow-hidden rounded-2xl border border-border bg-page/80 backdrop-blur">
        <div class="flex items-center gap-2 border-b border-border-soft px-4 py-2.5 text-xs text-muted">
          <span class="size-3 rounded-full bg-decline/70"></span>
          <span class="size-3 rounded-full bg-cat-deploy/70"></span>
          <span class="size-3 rounded-full bg-approve/70"></span>
          <span class="ml-2 font-sans">mcp.json</span>
          <button
            type="button"
            data-copy-config
            aria-label="Copy the mcp.json snippet"
            aria-live="polite"
            class="ml-auto rounded-md border border-border bg-surface/60 px-2.5 py-1 font-sans text-xs font-medium text-muted transition hover:bg-surface hover:text-text"
          >
            <span data-copy-label>Copy</span>
          </button>
        </div>
        <pre
          class="overflow-x-auto px-5 py-5 text-sm leading-relaxed text-text"
        ><code id="mcp-code">{mcpSnippet}</code></pre>
      </div>

      <!-- Copy-to-clipboard, shared by the hero/footer CTAs + the code-block button.
           Astro hashes this inline <script> into the build-synced CSP (script-src),
           so it runs without loosening the policy. Reads the snippet from #mcp-code;
           falls back to selecting it when the Clipboard API is unavailable. -->
      <script>
        const code = document.getElementById("mcp-code");
        const copyText = async (text: string): Promise<boolean> => {
          try {
            await navigator.clipboard.writeText(text);
            return true;
          } catch {
            try {
              if (!code) return false;
              const range = document.createRange();
              range.selectNodeContents(code);
              const sel = window.getSelection();
              sel?.removeAllRanges();
              sel?.addRange(range);
              const ok = document.execCommand("copy");
              sel?.removeAllRanges();
              return ok;
            } catch {
              return false;
            }
          }
        };
        document.querySelectorAll<HTMLElement>("[data-copy-config]").forEach((btn) => {
          const label = btn.querySelector<HTMLElement>("[data-copy-label]") ?? btn;
          const original = label.textContent ?? "";
          btn.addEventListener("click", async () => {
            if (!code) return;
            const ok = await copyText(code.textContent ?? "");
            label.textContent = ok ? "Copied!" : "Press Ctrl+C";
            window.setTimeout(() => {
              label.textContent = original;
            }, 1500);
          });
        });
      </script>
    </section>

    <!-- ───────────────────────── Works with (MCP clients) ───────────────────────── -->
    <section class="border-t border-border-soft/60">
      <div class="mx-auto max-w-4xl px-6 py-14 text-center">
        <p class="font-mono text-xs uppercase tracking-widest text-muted">
          Works with your agents
        </p>
        <div class="mt-5 flex flex-wrap items-center justify-center gap-2.5">
          {
            agents.map((a) => (
              <span
                class:list={[
                  "inline-flex items-center gap-2 rounded-full px-3.5 py-2 font-sans text-sm backdrop-blur transition hover:-translate-y-0.5",
                  a.highlight
                    ? "border border-approve/40 bg-approve/10 font-semibold text-approve"
                    : "border border-border bg-surface/50 text-muted hover:border-approve/60 hover:bg-surface hover:text-text",
                ]}
              >
                <span class="inline-flex shrink-0" set:html={a.svg} />
                {a.name}
              </span>
            ))
          }
        </div>
        <p class="mx-auto mt-6 max-w-md text-sm text-muted">
          If it speaks MCP, it can reach you. Same one-line config, zero extra setup.
        </p>
      </div>
    </section>

    <!-- ───────────────── It comes alive: real agent-request cards ───────────────── -->
    <section class="border-t border-border-soft/60">
      <div class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="font-sans text-2xl font-semibold tracking-tight text-text sm:text-3xl">
            This is what lands on your phone.
          </h2>
          <p class="mt-3 text-pretty text-muted">
            Pair once. After that, when an agent can't decide on its own, it
            rings your phone and waits: a yes or no, a choice, or a quick reply.
          </p>
        </div>

        <div class="mx-auto mt-10 grid max-w-3xl gap-4 sm:grid-cols-2">
          {
            cards.map((card) => (
              <div class="req-card rounded-2xl border border-border bg-surface/50 p-5 backdrop-blur">
                <div class="flex items-center gap-2.5">
                  {card.kind === "pair" ? (
                    <img src={PAGER} alt="" width="36" height="36" class="size-9 shrink-0" />
                  ) : (
                    <span
                      class="grid size-9 shrink-0 place-items-center text-text [&>svg]:size-7"
                      set:html={card.icon ?? ""}
                    />
                  )}
                  <div class="min-w-0">
                    <p class="truncate font-sans text-sm font-semibold text-text">{card.agent}</p>
                    <p class="text-xs text-muted">{card.sub}</p>
                  </div>
                  <span class="req-dot ml-auto size-2 shrink-0 rounded-full bg-approve" aria-hidden="true"></span>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-muted">{card.body}</p>

                {card.kind === "pair" && (
                  <div class="mt-4 flex items-center gap-2.5">
                    <span class="rounded-lg border border-border bg-page/70 px-3 py-1.5 font-mono text-sm tracking-[0.35em] text-text">
                      {card.code}
                    </span>
                    <span class="text-xs text-muted">type it in the app</span>
                  </div>
                )}

                {(card.kind === "yesno" || card.kind === "choice") && (
                  <div class="mt-4 flex flex-wrap gap-2" role="group" aria-label="Example response (preview)">
                    {(card.actions ?? []).map((a) => (
                      <span
                        class:list={[
                          "rounded-lg px-3 py-1.5 font-sans text-xs font-medium",
                          actionTone(a) === "approve" && "bg-approve/15 text-approve",
                          actionTone(a) === "decline" && "bg-decline/15 text-decline",
                          actionTone(a) === "neutral" && "border border-border bg-surface/60 text-muted",
                        ]}
                      >
                        {a}
                      </span>
                    ))}
                  </div>
                )}

                {card.kind === "text" && (
                  <div class="mt-4 flex items-center gap-2" role="group" aria-label="Example response (preview)">
                    <span class="flex-1 truncate rounded-lg border border-border bg-page/70 px-3 py-2 text-xs text-muted">
                      {card.placeholder}
                    </span>
                    <span class="shrink-0 rounded-lg bg-approve/15 px-3 py-2 font-sans text-xs font-medium text-approve">
                      Send
                    </span>
                  </div>
                )}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────────────────────── The flow ───────────────────────────── -->
    <section class="border-t border-border-soft/60">
      <div class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="font-sans text-2xl font-semibold tracking-tight text-text sm:text-3xl">
            Wall to phone to “keep going,” in seconds.
          </h2>
        </div>

        <!-- Plain numbered sequence (the visible 1..5 badges carry the order). Not an
             <ol>: the arrows are decorative, so keeping them out of list semantics
             avoids a mismatched item count for screen readers. -->
        <div class="mx-auto mt-10 flex max-w-3xl flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:justify-center">
          {
            flowSteps.map((step, i) => (
              <Fragment>
                {i > 0 && (
                  <span class="flow-arrow self-center text-approve/70" aria-hidden="true">
                    <span class="sm:hidden">↓</span>
                    <span class="hidden sm:inline">→</span>
                  </span>
                )}
                <div class="flex flex-1 items-center gap-2.5 rounded-xl border border-border bg-surface/50 px-3.5 py-3 text-sm text-muted backdrop-blur sm:flex-col sm:gap-2 sm:text-center">
                  <span class="grid size-6 shrink-0 place-items-center rounded-full bg-approve/15 font-sans text-xs font-semibold text-approve">
                    {i + 1}
                  </span>
                  <span class="leading-snug">{step}</span>
                </div>
              </Fragment>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────────────────── Why we built this ───────────────────────── -->
    <section class="border-t border-border-soft/60">
      <div class="mx-auto max-w-2xl px-6 py-20 sm:py-24">
        <h2 class="font-sans text-2xl font-semibold tracking-tight text-text sm:text-3xl">
          Why we built this
        </h2>
        <div class="mt-6 space-y-5 text-pretty leading-relaxed text-muted">
          {whyParagraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <!-- ───────────── For the curious: the crypto, demoted but proud ───────────── -->
    <section class="border-t border-border-soft/60">
      <div class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
        <div class="max-w-2xl">
          <span
            class="inline-flex items-center gap-2 rounded-full border border-border bg-surface/60 px-3 py-1 text-xs font-medium text-muted backdrop-blur"
          >
            <span class="size-1.5 rounded-full bg-cat-access"></span>
            For the curious
          </span>
          <h2 class="mt-4 font-sans text-2xl font-semibold tracking-tight text-text sm:text-3xl">
            The crypto bit.
          </h2>
          <p class="mt-3 text-pretty text-muted">
            Pairing is a Magic-Wormhole-style <strong class="text-text">SPAKE2</strong> handshake:
            that short code turns into a strong shared key, and even if someone shoulder-surfs it
            they get exactly <strong class="text-text">one</strong> online guess before it's useless.
            After that, every message is sealed with NaCl
            <code class="rounded bg-surface px-1.5 py-0.5 text-sm text-text">secretbox</code>
            (XSalsa20-Poly1305). The relay only ever sees base64(nonce‖ciphertext) and which room is
            talking to which, never the contents.
          </p>
        </div>

        <!-- agent <-sealed-> relay <-sealed-> phone, with the SPAKE2 shared key the relay
             never sees. Theme-aware (fill-*/stroke-* map to design tokens), pure SVG. -->
        <div class="mt-10 rounded-2xl border border-border bg-surface/30 p-6 backdrop-blur sm:p-8">
          <svg
            viewBox="0 0 720 250"
            role="img"
            aria-labelledby="wh-title wh-desc"
            class="mx-auto h-auto w-full max-w-3xl font-sans"
          >
            <title id="wh-title">How ask-a-human pairs and seals approvals</title>
            <desc id="wh-desc">
              Your agent and your phone derive a shared key from a short code via SPAKE2; the
              relay in the middle only ever forwards ciphertext.
            </desc>
            <defs>
              <marker id="wh-arrow" markerWidth="7" markerHeight="7" refX="5.5" refY="3" orient="auto">
                <path d="M0,0 L6,3 L0,6 Z" class="fill-muted"></path>
              </marker>
            </defs>

            <text x="360" y="32" text-anchor="middle" class="fill-text" font-size="13.5" font-weight="600">
              The relay only forwards ciphertext.
            </text>
            <text x="360" y="52" text-anchor="middle" class="fill-muted" font-size="11">
              base64(nonce‖ciphertext) + which room talks to which, never the data
            </text>

            <line x1="210" y1="116" x2="268" y2="116" class="stroke-border" stroke-width="1.5" marker-start="url(#wh-arrow)" marker-end="url(#wh-arrow)"></line>
            <line x1="452" y1="116" x2="510" y2="116" class="stroke-border" stroke-width="1.5" marker-start="url(#wh-arrow)" marker-end="url(#wh-arrow)"></line>
            <text x="239" y="104" text-anchor="middle" class="fill-muted" font-size="11">sealed</text>
            <text x="481" y="104" text-anchor="middle" class="fill-muted" font-size="11">sealed</text>

            <rect x="28" y="84" width="180" height="72" rx="14" class="fill-surface-2 stroke-border" stroke-width="1.5"></rect>
            <text x="118" y="116" text-anchor="middle" class="fill-text" font-size="15" font-weight="600">Your agent</text>
            <text x="118" y="136" text-anchor="middle" class="fill-muted" font-size="11.5">MCP · holds the key</text>

            <rect x="270" y="84" width="180" height="72" rx="14" class="fill-surface-2 stroke-border" stroke-width="1.5"></rect>
            <text x="360" y="116" text-anchor="middle" class="fill-text" font-size="15" font-weight="600">Relay</text>
            <text x="360" y="136" text-anchor="middle" class="fill-muted" font-size="11.5">content-blind</text>

            <rect x="512" y="84" width="180" height="72" rx="14" class="fill-surface-2 stroke-border" stroke-width="1.5"></rect>
            <text x="602" y="116" text-anchor="middle" class="fill-text" font-size="15" font-weight="600">Your phone</text>
            <text x="602" y="136" text-anchor="middle" class="fill-muted" font-size="11.5">holds the key</text>

            <path d="M118,160 C118,202 602,202 602,160" fill="none" class="stroke-approve" stroke-width="1.5" stroke-dasharray="5 5"></path>
