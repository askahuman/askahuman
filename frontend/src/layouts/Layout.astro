---
import "../styles/global.css";
// pwaInfo is injected by @vite-pwa/astro; holds the manifest <link> + web manifest icon.
import { pwaInfo } from "virtual:pwa-info";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ask-a-human",
  description = "End-to-end-encrypted approvals from your AI agents, on your phone.",
} = Astro.props;

const THEME_COLOR = "#08090c";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Defense-in-depth: the pairing code is typed and never placed in any URL,
         but we still suppress the Referer header so no app URL leaks to third
         parties. nginx also sends Referrer-Policy. -->
    <meta name="referrer" content="no-referrer" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- PWA: theme color + manifest link (manifest injected by vite-plugin-pwa). -->
    <meta name="theme-color" content={THEME_COLOR} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/svg+xml" href="/icons/pager-favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

    <!-- The app is dark-only: <html class="dark"> above pins it before paint (no
         FOUC). No theme-toggle script here: a <script is:inline> would be blocked
         by the strict CSP (is:inline scripts aren't hashed into script-src), and
         nothing in the app ever stores a light theme. Mirrors LandingLayout. -->
  </head>
  <body class="app-shell min-h-screen overflow-x-hidden">
    <slot />

    <!-- Register the service worker (autoUpdate). -->
    <script>
      import { registerSW } from "virtual:pwa-register";
      registerSW({ immediate: true });
    </script>
  </body>
</html>
